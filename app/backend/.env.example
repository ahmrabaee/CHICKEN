# =============================================================================
# Environment Template
# Copy this file to .env and configure for your environment
# =============================================================================

# Database (SQLite)
DATABASE_URL="file:./data/chicken_shop.db"
# Backup metadata database (kept separate from main app DB)
BACKUP_META_DATABASE_URL="file:./data/backup-meta.db"
# Auto backup schedule cron (default 2:00 AM daily). Example: "18 1 * * *" = 01:18 AM every day.
BACKUP_SCHEDULE_CRON="0 2 * * *"

# Environment
NODE_ENV="development"

# Logging
LOG_LEVEL="debug"
