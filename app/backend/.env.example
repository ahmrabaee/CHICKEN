# =============================================================================
# Production Environment Template
# Copy this file to .env on the server and fill in the values.
# NEVER commit .env to Git.
# =============================================================================

# ── Database (SQLite) ─────────────────────────────────────────────────────────
# Absolute path is safest for production (avoids cwd ambiguity)
DATABASE_URL="file:/home/chicken/app/backend/data/chicken_shop.db"
BACKUP_META_DATABASE_URL="file:/home/chicken/app/backend/data/backup-meta.db"

# ── Auto-backup cron schedule ─────────────────────────────────────────────────
# Default: 2:00 AM every day
BACKUP_SCHEDULE_CRON="0 2 * * *"

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV="production"

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="info"

# ── Server Port ───────────────────────────────────────────────────────────────
# Caddy reverse proxy forwards HTTPS to this port internally.
# Do NOT open port 3000 in the firewall.
PORT=3000

# ── JWT Secret ────────────────────────────────────────────────────────────────
# REQUIRED. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_GENERATE_A_RANDOM_64_CHAR_STRING"
