# Caddyfile — Chicken Shop Backend Reverse Proxy
#
# Instructions:
# 1. Replace "api.yourdomain.com" with your actual domain
# 2. Copy this file to /etc/caddy/Caddyfile on the server
# 3. Run: systemctl reload caddy
#
# Caddy automatically handles HTTPS via Let's Encrypt.
# Your domain DNS A record must point to this server's IP first.

api.yourdomain.com {

    # Forward all traffic to the NestJS backend
    reverse_proxy localhost:3000

    # ── Optional: restrict Swagger to admin IPs only ──────────────────────────
    # Uncomment and replace YOUR_ADMIN_IP to hide /api/docs from the internet:
    #
    # @swagger path /api/docs*
    # handle @swagger {
    #     @allowed remote_ip YOUR_ADMIN_IP
    #     handle @allowed {
    #         reverse_proxy localhost:3000
    #     }
    #     respond 403
    # }

    # ── Security Headers ─────────────────────────────────────────────────────
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
    }

    # ── Access Logs ──────────────────────────────────────────────────────────
    log {
        output file /var/log/caddy/chicken-access.log {
            roll_size 50mb
            roll_keep 10
        }
        format json
    }
}
