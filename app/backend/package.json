{
  "name": "chicken-shop-backend",
  "version": "1.0.0",
  "description": "Chicken Shop POS Backend - SQLite with Prisma ORM",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest"
  },
  "keywords": ["pos", "inventory", "accounting", "sqlite", "prisma"],
  "license": "UNLICENSED",
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.13.1",
    "prisma": "^6.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
