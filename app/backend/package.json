{
  "name": "chicken-shop-backend",
  "version": "1.0.0",
  "description": "Chicken Shop POS Backend - NestJS with Prisma ORM",
  "main": "dist/main.js",
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts --profile=baseline",
    "db:seed:baseline": "tsx prisma/seed.ts --profile=baseline",
    "db:seed:dev": "tsx prisma/seed.ts --profile=dev",
    "db:seed:test": "tsx prisma/seed.ts --profile=test",
    "db:reset:baseline": "npm run db:push -- --force-reset && npm run db:seed:baseline",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "db:reset-setup": "tsx scripts/reset-setup.ts",
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "test": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "keywords": [
    "pos",
    "inventory",
    "accounting",
    "sqlite",
    "prisma",
    "nestjs"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@anatine/zod-nestjs": "^2.0.9",
    "@anatine/zod-openapi": "^2.2.6",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^8.1.0",
    "@prisma/client": "^6.3.0",
    "@types/tar": "^6.1.13",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfmake": "^0.3.4",
    "pdfmake-rtl": "^2.1.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "tar": "^7.5.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdfmake": "^0.3.1",
    "prisma": "^6.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
