// =============================================================================
// Chicken Shop POS, Inventory & Accounting System
// Prisma Schema v1.0.0
// 
// Database: SQLite
// All monetary values in minor units (fils/cents), weights in grams
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// SECTION 1: CORE SYSTEM TABLES
// =============================================================================

/// Shop locations/branches for multi-branch support
/// PRD Section: 2.1 - Branch/Outlet Configuration
/// Blueprint 06: stockAccountId for Warehouse→Account mapping
model Branch {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  name            String // Arabic name (primary)
  nameEn          String?  @map("name_en")
  address         String?
  phone           String?
  hasScale        Boolean  @default(true) @map("has_scale")
  scaleComPort    String?  @map("scale_com_port")
  isMainBranch    Boolean  @default(false) @map("is_main_branch")
  isActive        Boolean  @default(true) @map("is_active")
  stockAccountId  Int?     @map("stock_account_id") // Blueprint 06: per-branch stock account
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  users             User[]              @relation("DefaultBranch")
  inventory         Inventory[]
  inventoryLots      InventoryLot[]
  stockMovements    StockMovement[]
  stockLedgerEntries StockLedgerEntry[] @relation("BranchStockLedger")
  wastageRecords    WastageRecord[]
  sales             Sale[]
  purchases         Purchase[]
  payments          Payment[]
  debts             Debt[]
  expenses          Expense[]
  journalEntries    JournalEntry[]
  auditLogs         AuditLog[]
  stockAccount      Account?            @relation(fields: [stockAccountId], references: [id], onDelete: SetNull)
  creditNotes       CreditNote[]
  stockTransfers    StockTransfer[] @relation("StockTransferBranch")

  @@map("branches")
}

/// System roles (Admin and Accountant per PRD)
/// PRD Section: 3.1 - Role Definitions
model Role {
  id           Int      @id @default(autoincrement())
  name         String   @unique // 'admin' or 'accountant'
  nameAr       String   @map("name_ar")
  description  String?
  permissions  String? // JSON array: ["sales.create", "sales.view", ...]
  isSystemRole Boolean  @default(false) @map("is_system_role")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  userRoles      UserRole[]
  rolePageAccess RolePageAccess[]

  @@map("roles")
}

/// Page definitions for dynamic access control (DYNAMIC_PAGE_ACCESS_PLAN)
model PageDefinition {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  path        String
  titleAr     String   @map("title_ar")
  titleEn     String?  @map("title_en")
  groupKey    String?  @map("group_key")
  sortOrder   Int      @default(0) @map("sort_order")
  isAdminOnly Boolean  @default(false) @map("is_admin_only")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePageAccess RolePageAccess[]
  userPageAccess UserPageAccess[]

  @@map("page_definitions")
}

/// Role-to-page access mapping (legacy default template - can be removed later)
model RolePageAccess {
  id        Int      @id @default(autoincrement())
  roleId    Int      @map("role_id")
  pageId    Int      @map("page_id")
  allowed   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  role Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  page PageDefinition @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([roleId, pageId])
  @@map("role_page_access")
}

/// Per-user page access - each accountant has their own permissions
model UserPageAccess {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  pageId    Int      @map("page_id")
  allowed   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  page PageDefinition  @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([userId, pageId])
  @@map("user_page_access")
}

/// System users (owners, cashiers)
/// PRD Section: 4.2.8 - Users & Authentication
model User {
  id                    Int       @id @default(autoincrement())
  username              String    @unique
  email                 String?   @unique
  passwordHash          String    @map("password_hash")
  fullName              String    @map("full_name")
  fullNameEn            String?   @map("full_name_en")
  phone                 String?
  employeeNumber        String?   @unique @map("employee_number")
  preferredLanguage     String    @default("ar") @map("preferred_language")
  defaultBranchId       Int?      @map("default_branch_id")
  lastLoginAt           DateTime? @map("last_login_at")
  refreshToken          String?   @map("refresh_token")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")

  // NEW FIELDS - PRD Requirements: User tracking and session management
  workStartDate        DateTime  @default(now()) @map("work_start_date")
  currentSessionToken  String?   @map("current_session_token")
  currentSessionExpiry DateTime? @map("current_session_expiry")

  isActive    Boolean  @default(true) @map("is_active")
  metadata    String? // JSON
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById Int?     @map("created_by")
  updatedById Int?     @map("updated_by")

  // Self-referential relations
  createdBy User? @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("UserUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  // Relations
  defaultBranch         Branch?         @relation("DefaultBranch", fields: [defaultBranchId], references: [id], onDelete: SetNull)
  userRoles             UserRole[]
  userPageAccess        UserPageAccess[]
  usersCreated          User[]          @relation("UserCreatedBy")
  usersUpdated          User[]          @relation("UserUpdatedBy")
  rolesAssigned         UserRole[]      @relation("AssignedBy")
  itemsCreated          Item[]          @relation("ItemCreatedBy")
  itemsUpdated          Item[]          @relation("ItemUpdatedBy")
  inventoryLotsCreated  InventoryLot[]  @relation("LotCreatedBy")
  stockMovements        StockMovement[]
  wastageRecorded       WastageRecord[] @relation("WastageRecordedBy")
  wastageApproved       WastageRecord[] @relation("WastageApprovedBy")
  customersCreated      Customer[]      @relation("CustomerCreatedBy")
  customersUpdated      Customer[]      @relation("CustomerUpdatedBy")
  suppliersCreated      Supplier[]      @relation("SupplierCreatedBy")
  suppliersUpdated      Supplier[]      @relation("SupplierUpdatedBy")
  salesAsCashier        Sale[]          @relation("SaleCashier")
  salesVoided           Sale[]          @relation("SaleVoidedBy")
  salesCancelled        Sale[]          @relation("SaleCancelledBy")
  salesSubmitted        Sale[]          @relation("SaleSubmittedBy")
  salesCreated          Sale[]          @relation("SaleCreatedBy")
  purchasesReceived     Purchase[]      @relation("PurchaseReceivedBy")
  purchasesApproved     Purchase[]      @relation("PurchaseApprovedBy")
  purchasesCreated      Purchase[]      @relation("PurchaseCreatedBy")
  stockTransfersCreated StockTransfer[] @relation("StockTransferCreatedBy")
  stockTransfersCompleted StockTransfer[] @relation("StockTransferCompletedBy")
  paymentsReceived      Payment[]
  paymentsCancelled     Payment[]       @relation("PaymentCancelledBy")
  expensesApproved      Expense[]       @relation("ExpenseApprovedBy")
  expensesCreated       Expense[]       @relation("ExpenseCreatedBy")
  journalEntriesCreated JournalEntry[]
  auditLogs             AuditLog[]
  accountingPeriodsClosed AccountingPeriod[]
  creditNotesCreated    CreditNote[]

  @@map("users")
}

/// Links users to roles (many-to-many)
/// PRD Section: 3.1
model UserRole {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  roleId       Int      @map("role_id")
  assignedAt   DateTime @default(now()) @map("assigned_at")
  assignedById Int?     @map("assigned_by")

  // Relations
  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("AssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// =============================================================================
// SECTION 2: PRODUCT & INVENTORY TABLES
// =============================================================================

/// Chicken product categories
/// PRD Section: 4.2.1 - Product Categories
model Category {
  id                   Int      @id @default(autoincrement())
  code                 String   @unique
  name                 String // Arabic name (primary)
  nameEn               String?  @map("name_en")
  displayOrder         Int      @default(0) @map("display_order")
  icon                 String?
  defaultShelfLifeDays Int?     @map("default_shelf_life_days")
  storageType          String?  @map("storage_type") // 'fresh', 'frozen', 'processed'
  purchaseItemId       Int?     @map("purchase_item_id") // Item used when purchasing this category (e.g. raw chicken)
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  items        Item[]
  purchaseItem Item?    @relation("CategoryPurchaseItem", fields: [purchaseItemId], references: [id], onDelete: SetNull)

  @@map("categories")
}

/// Products sold by weight (kg only per PRD)
/// PRD Section: 4.2.1 - Item (Chicken product master)
model Item {
  id                   Int      @id @default(autoincrement())
  code                 String   @unique
  barcode              String?  @unique
  name                 String // Arabic name (primary)
  nameEn               String?  @map("name_en")
  description          String?
  categoryId           Int      @map("category_id")
  defaultSalePrice     Int      @map("default_sale_price") // Minor units per kg
  defaultPurchasePrice Int?     @map("default_purchase_price")
  taxRatePct           Int?     @map("tax_rate_pct") // Basis points
  minStockLevelGrams   Int?     @map("min_stock_level_grams")
  maxStockLevelGrams   Int?     @map("max_stock_level_grams")
  shelfLifeDays        Int?     @map("shelf_life_days")
  storageLocation      String?  @map("storage_location") // 'fridge', 'freezer', 'display'
  requiresScale        Boolean  @default(true) @map("requires_scale")
  allowNegativeStock   Boolean  @default(false) @map("allow_negative_stock")
  imageUrl             String?  @map("image_url")
  metadata             String? // JSON
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  createdById          Int?     @map("created_by")
  updatedById          Int?     @map("updated_by")

  // Relations
  category            Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  purchaseCategories  Category[]      @relation("CategoryPurchaseItem")
  createdBy           User?           @relation("ItemCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?           @relation("ItemUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  inventory          Inventory?
  inventoryLots      InventoryLot[]
  stockMovements     StockMovement[]
  stockLedgerEntries StockLedgerEntry[]
  wastageRecords     WastageRecord[]
  saleLines          SaleLine[]
  purchaseLines      PurchaseLine[]
  stockTransferLines StockTransferLine[]

  @@index([categoryId])
  @@index([name])
  @@index([isActive])
  @@map("items")
}

/// Current stock summary per item (1:1 with Item)
/// PRD Section: 4.2.2
model Inventory {
  id                    Int       @id @default(autoincrement())
  itemId                Int       @unique @map("item_id")
  branchId              Int?      @map("branch_id")
  currentQuantityGrams  Int       @default(0) @map("current_quantity_grams")
  reservedQuantityGrams Int       @default(0) @map("reserved_quantity_grams")
  totalValue            Int       @default(0) @map("total_value") // Minor units
  averageCost           Int       @default(0) @map("average_cost") // Minor units per kg
  lastRestockedAt       DateTime? @map("last_restocked_at")
  lastSoldAt            DateTime? @map("last_sold_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relations
  item   Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@map("inventory")
}

/// Individual inventory lots for FIFO cost allocation
/// PRD Section: 4.2.2 - FIFO lot tracking
model InventoryLot {
  id                     Int       @id @default(autoincrement())
  itemId                 Int       @map("item_id")
  purchaseId             Int?      @map("purchase_id")
  purchaseLineId         Int?      @map("purchase_line_id")
  stockTransferId        Int?      @map("stock_transfer_id")
  branchId               Int?      @map("branch_id")
  lotNumber              String    @unique @map("lot_number")
  batchNumber            String?   @map("batch_number")
  totalQuantityGrams     Int       @map("total_quantity_grams")
  remainingQuantityGrams Int       @map("remaining_quantity_grams")
  unitPurchasePrice      Int       @map("unit_purchase_price") // Minor units per kg
  receivedAt             DateTime  @default(now()) @map("received_at")
  expiryDate             DateTime? @map("expiry_date")
  metadata               String? // JSON: gross_weight, net_weight, shrinkage
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  createdById            Int?      @map("created_by")

  // Relations
  item            Item                     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  purchase        Purchase?                @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  purchaseLine    PurchaseLine?            @relation(fields: [purchaseLineId], references: [id], onDelete: SetNull)
  stockTransfer       StockTransfer?     @relation(fields: [stockTransferId], references: [id], onDelete: SetNull)
  sourceStockTransfers StockTransfer[]   @relation("StockTransferSource")
  branch              Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBy       User?                    @relation("LotCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  stockMovements  StockMovement[]
  wastageRecords  WastageRecord[]
  costAllocations SaleLineCostAllocation[]

  @@index([itemId, receivedAt])
  @@index([expiryDate])
  @@index([branchId])
  @@index([purchaseId])
  @@index([stockTransferId])
  @@map("inventory_lots")
}

/// Stock transfer: convert raw chicken inventory to products (wings, breast, whole, etc.)
/// plan_of_wastage.md
model StockTransfer {
  id                 Int       @id @default(autoincrement())
  transferNumber     String    @unique @map("transfer_number")
  sourceLotId        Int       @map("source_lot_id")
  transferDate       DateTime  @default(now()) @map("transfer_date")
  branchId           Int?      @map("branch_id")
  expiryDate         DateTime  @map("expiry_date")
  totalWeightGrams   Int       @map("total_weight_grams")
  totalCostValue     Int       @default(0) @map("total_cost_value")
  status             String    @default("draft") @map("status") // draft, completed, cancelled
  notes              String?
  createdById        Int?      @map("created_by")
  completedAt        DateTime? @map("completed_at")
  completedById      Int?      @map("completed_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Relations
  sourceLot     InventoryLot       @relation("StockTransferSource", fields: [sourceLotId], references: [id], onDelete: Restrict)
  branch        Branch?           @relation("StockTransferBranch", fields: [branchId], references: [id], onDelete: SetNull)
  createdBy     User?             @relation("StockTransferCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  completedBy   User?             @relation("StockTransferCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  lines         StockTransferLine[]
  inventoryLots InventoryLot[]

  @@index([transferDate])
  @@index([status])
  @@index([sourceLotId])
  @@index([branchId])
  @@map("stock_transfers")
}

model StockTransferLine {
  id                Int       @id @default(autoincrement())
  stockTransferId   Int       @map("stock_transfer_id")
  itemId            Int       @map("item_id")
  lineNumber        Int       @map("line_number")
  weightGrams       Int       @map("weight_grams")
  unitCost          Int       @map("unit_cost") // minor units per kg
  lineCostValue     Int       @map("line_cost_value")
  createdAt         DateTime  @default(now()) @map("created_at")

  // Relations
  stockTransfer StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  item          Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([stockTransferId, lineNumber])
  @@index([itemId])
  @@map("stock_transfer_lines")
}

/// Audit trail for inventory changes
/// PRD Section: 4.2.2
model StockMovement {
  id            Int      @id @default(autoincrement())
  itemId        Int      @map("item_id")
  lotId         Int?     @map("lot_id")
  branchId      Int?     @map("branch_id")
  movementType  String   @map("movement_type") // 'purchase', 'sale', 'adjustment', 'transfer', 'waste', 'opening'
  quantityGrams Int      @map("quantity_grams") // Positive = in, Negative = out
  unitCost      Int?     @map("unit_cost")
  referenceType String?  @map("reference_type")
  referenceId   Int?     @map("reference_id")
  fromBranchId  Int?     @map("from_branch_id")
  toBranchId    Int?     @map("to_branch_id")
  reason        String?
  movementDate  DateTime @default(now()) @map("movement_date")
  performedById Int?     @map("performed_by")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  item        Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  lot         InventoryLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  branch      Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  performedBy User?         @relation(fields: [performedById], references: [id], onDelete: SetNull)

  @@index([itemId, movementDate])
  @@index([movementType])
  @@index([branchId])
  @@map("stock_movements")
}

/// Blueprint 06: Stock Ledger Entry - immutable accounting ledger for inventory
/// Source of truth for stock valuation; links to GL via voucher_type/voucher_id
model StockLedgerEntry {
  id                    Int      @id @default(autoincrement())
  itemId                Int      @map("item_id")
  branchId              Int?     @map("branch_id")

  voucherType           String   @map("voucher_type") // 'sale', 'purchase', 'adjustment', 'wastage', 'transfer'
  voucherId             Int      @map("voucher_id")
  voucherDetailNo       String?  @map("voucher_detail_no")

  qtyChange             Int      @map("qty_change") // positive=in, negative=out (grams)
  valuationRate         Int      @map("valuation_rate") // minor units per kg
  stockValueDifference  Int      @map("stock_value_difference") // minor units

  postingDate           DateTime @map("posting_date")
  postingTime          String?  @map("posting_time")
  remarks               String?
  createdAt             DateTime @default(now()) @map("created_at")

  item   Item     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  branch Branch?  @relation("BranchStockLedger", fields: [branchId], references: [id], onDelete: SetNull)

  @@index([itemId, branchId])
  @@index([voucherType, voucherId])
  @@index([postingDate])
  @@index([branchId])
  @@map("stock_ledger_entries")
}

/// Spoilage, trimming, expiry tracking
/// PRD Section: 4.2.2 - Critical for chicken shop daily tracking
model WastageRecord {
  id                 Int       @id @default(autoincrement())
  itemId             Int       @map("item_id")
  lotId              Int?      @map("lot_id")
  branchId           Int?      @map("branch_id")
  weightGrams        Int       @map("weight_grams")
  wastageType        String    @map("wastage_type") // 'spoilage', 'trimming', 'expired', 'damaged', 'end_of_day', 'other'
  reason             String
  estimatedCostValue Int       @default(0) @map("estimated_cost_value") // Minor units
  photoUrl           String?   @map("photo_url")
  recordedById       Int       @map("recorded_by")
  approvedById       Int?      @map("approved_by")
  approvedAt         DateTime? @map("approved_at")
  wastageDate        DateTime  @default(now()) @map("wastage_date")
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Blueprint 03: Posting workflow (wastage submitted on record)
  docstatus   Int       @default(1) @map("docstatus") // 1=Submitted
  submittedAt DateTime? @map("submitted_at")
  submittedById Int?    @map("submitted_by")

  // Relations
  item       Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  lot        InventoryLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  branch     Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  recordedBy User          @relation("WastageRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)
  approvedBy User?         @relation("WastageApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([wastageDate])
  @@index([wastageType])
  @@index([docstatus])
  @@map("wastage_records")
}

// =============================================================================
// SECTION 3: PARTIES (CUSTOMERS & SUPPLIERS)
// =============================================================================

/// Customers with credit management
/// PRD Section: 4.2.6 - Customer master
model Customer {
  id                 Int      @id @default(autoincrement())
  customerNumber     String   @unique @map("customer_number")
  name               String // Arabic name (primary)
  nameEn             String?  @map("name_en")
  phone              String?
  phone2             String?
  email              String?
  address            String?
  creditLimit        Int      @default(0) @map("credit_limit") // Minor units
  currentBalance     Int      @default(0) @map("current_balance") // Computed
  priceLevel         String   @default("standard") @map("price_level") // 'standard', 'wholesale', 'vip'
  defaultDiscountPct Int      @default(0) @map("default_discount_pct") // Basis points
  taxNumber          String?  @map("tax_number")
  metadata           String? // JSON
  notes              String?
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  createdById        Int?     @map("created_by")
  updatedById        Int?     @map("updated_by")

  // Relations
  createdBy User?  @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?  @relation("CustomerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  sales     Sale[]

  @@index([phone])
  @@index([isActive])
  @@map("customers")
}

/// Chicken suppliers/farms
/// PRD Section: 4.2.6 - Supplier master
model Supplier {
  id                Int      @id @default(autoincrement())
  supplierNumber    String   @unique @map("supplier_number")
  name              String // Arabic name (primary)
  nameEn            String?  @map("name_en")
  phone             String?
  email             String?
  address           String?
  contactPerson     String?  @map("contact_person")
  taxNumber         String?  @map("tax_number")
  paymentTerms      String?  @map("payment_terms")
  currentBalance    Int      @default(0) @map("current_balance") // Computed
  creditLimit       Int?     @map("credit_limit")
  bankName          String?  @map("bank_name")
  bankAccountNumber String?  @map("bank_account_number")
  rating            Int? // 1-5
  metadata          String?
  notes             String?
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  createdById       Int?     @map("created_by")
  updatedById       Int?     @map("updated_by")

  // Relations
  createdBy User?      @relation("SupplierCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?      @relation("SupplierUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  purchases Purchase[]
  expenses  Expense[]

  @@index([isActive])
  @@map("suppliers")
}

// =============================================================================
// SECTION 4: TRANSACTIONS (SALES, PURCHASES, PAYMENTS, DEBTS)
// =============================================================================

/// Sales invoices with FIFO cost tracking
/// PRD Section: 4.2.3 - Sales header
/// Blueprint 03: docstatus (0=Draft, 1=Submitted, 2=Cancelled)
model Sale {
  id               Int       @id @default(autoincrement())
  saleNumber       String    @unique @map("sale_number")
  saleDate         DateTime  @default(now()) @map("sale_date")
  saleType         String    @default("cash") @map("sale_type") // 'cash', 'credit', 'mixed'
  customerId       Int?      @map("customer_id")
  customerName     String?   @map("customer_name")
  customerPhone    String?   @map("customer_phone")
  cashierId        Int       @map("cashier_id")
  branchId         Int?      @map("branch_id")
  grossTotalAmount Int       @default(0) @map("gross_total_amount") // Minor units
  discountAmount   Int       @default(0) @map("discount_amount")
  discountPct      Int?      @map("discount_pct") // Basis points
  taxAmount        Int       @default(0) @map("tax_amount")
  totalAmount      Int       @default(0) @map("total_amount")

  // Blueprint 05: Tax Engine
  taxTemplateId   Int?      @map("tax_template_id")
  netTotal        Int?      @map("net_total")       // Before tax (minor units)
  totalTaxAmount  Int       @default(0) @map("total_tax_amount")
  grandTotal      Int?      @map("grand_total")     // netTotal + totalTaxAmount
  totalCost        Int       @default(0) @map("total_cost")
  totalProfit      Int       @default(0) @map("total_profit")
  paymentStatus    String    @default("unpaid") @map("payment_status") // 'unpaid', 'partial', 'paid'
  amountPaid       Int       @default(0) @map("amount_paid")
  dueDate          DateTime? @map("due_date")
  isVoided         Boolean   @default(false) @map("is_voided")
  voidedAt         DateTime? @map("voided_at")
  voidedById       Int?      @map("voided_by")
  voidReason       String?   @map("void_reason")
  notes            String?
  metadata         String? // JSON
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  createdById      Int?      @map("created_by")

  // Blueprint 03: Posting workflow (ERP-level docstatus)
  docstatus       Int       @default(1) @map("docstatus") // 0=Draft, 1=Submitted, 2=Cancelled
  submittedAt     DateTime? @map("submitted_at")
  submittedById   Int?      @map("submitted_by")
  cancelledAt     DateTime? @map("cancelled_at")
  cancelledById   Int?      @map("cancelled_by")
  cancelReason    String?   @map("cancel_reason")

  // Relations
  customer    Customer?  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  cashier     User       @relation("SaleCashier", fields: [cashierId], references: [id], onDelete: Restrict)
  branch      Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  voidedBy    User?      @relation("SaleVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)
  cancelledBy User?      @relation("SaleCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  submittedBy User?      @relation("SaleSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  createdBy   User?      @relation("SaleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  saleLines   SaleLine[]
  taxTemplate TaxTemplate?    @relation(fields: [taxTemplateId], references: [id], onDelete: SetNull)
  taxBreakdowns SaleTaxBreakdown[]

  @@index([saleDate])
  @@index([customerId])
  @@index([cashierId])
  @@index([branchId])
  @@index([paymentStatus])
  @@index([docstatus])
  @@map("sales")
}

/// Sales line items (weight-based)
/// PRD Section: 4.2.3
model SaleLine {
  id              Int      @id @default(autoincrement())
  saleId          Int      @map("sale_id")
  lineNumber      Int      @map("line_number")
  itemId          Int      @map("item_id")
  itemName        String   @map("item_name")
  itemCode        String   @map("item_code")
  weightGrams     Int      @map("weight_grams")
  pricePerKg      Int      @map("price_per_kg") // Minor units
  discountAmount  Int      @default(0) @map("discount_amount")
  netPricePerKg   Int      @map("net_price_per_kg")
  taxRatePct      Int      @default(0) @map("tax_rate_pct") // Basis points
  taxAmount       Int      @default(0) @map("tax_amount")
  lineTotalAmount Int      @map("line_total_amount")
  costPerKg       Int      @default(0) @map("cost_per_kg")
  lineTotalCost   Int      @default(0) @map("line_total_cost")
  metadata        String? // JSON
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  sale            Sale                     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  item            Item                     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  costAllocations SaleLineCostAllocation[]

  @@unique([saleId, lineNumber])
  @@index([itemId])
  @@map("sale_lines")
}

/// FIFO cost tracking - links sale lines to inventory lots
/// PRD Section: 4.2.3
model SaleLineCostAllocation {
  id                     Int      @id @default(autoincrement())
  saleLineId             Int      @map("sale_line_id")
  lotId                  Int      @map("lot_id")
  quantityAllocatedGrams Int      @map("quantity_allocated_grams")
  unitCost               Int      @map("unit_cost") // Minor units per kg
  totalCost              Int      @map("total_cost")
  createdAt              DateTime @default(now()) @map("created_at")

  // Relations
  saleLine SaleLine     @relation(fields: [saleLineId], references: [id], onDelete: Cascade)
  lot      InventoryLot @relation(fields: [lotId], references: [id], onDelete: Restrict)

  @@index([saleLineId])
  @@index([lotId])
  @@map("sale_line_cost_allocations")
}

/// Purchase orders
/// PRD Section: 4.2.4
model Purchase {
  id                    Int       @id @default(autoincrement())
  purchaseNumber        String    @unique @map("purchase_number")
  purchaseDate          DateTime  @default(now()) @map("purchase_date")
  supplierId            Int       @map("supplier_id")
  supplierName          String    @map("supplier_name")
  supplierInvoiceNumber String?   @map("supplier_invoice_number")
  totalAmount           Int       @default(0) @map("total_amount") // Minor units
  taxAmount             Int       @default(0) @map("tax_amount")
  paymentStatus         String    @default("unpaid") @map("payment_status")

  // Blueprint 05: Tax Engine
  taxTemplateId   Int?      @map("tax_template_id")
  netTotal        Int?      @map("net_total")
  totalTaxAmount  Int       @default(0) @map("total_tax_amount")
  grandTotal      Int?      @map("grand_total")
  amountPaid            Int       @default(0) @map("amount_paid")
  dueDate               DateTime? @map("due_date")
  receivedById          Int?      @map("received_by")
  receivedAt            DateTime? @map("received_at")
  isApproved            Boolean   @default(false) @map("is_approved")
  approvedById          Int?      @map("approved_by")
  approvedAt            DateTime? @map("approved_at")
  branchId              Int?      @map("branch_id")
  notes                 String?
  metadata              String? // JSON: live bird details
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  createdById           Int?      @map("created_by")

  // Blueprint 03: Posting workflow (ERP-level docstatus)
  docstatus     Int       @default(0) @map("docstatus") // 0=Draft, 1=Submitted, 2=Cancelled
  submittedAt   DateTime? @map("submitted_at")
  submittedById Int?      @map("submitted_by")
  cancelledAt   DateTime? @map("cancelled_at")
  cancelledById Int?      @map("cancelled_by")
  cancelReason  String?   @map("cancel_reason")

  // Relations
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  receivedBy    User?          @relation("PurchaseReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)
  approvedBy    User?          @relation("PurchaseApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  branch        Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBy     User?          @relation("PurchaseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  purchaseLines PurchaseLine[]
  inventoryLots InventoryLot[]
  taxTemplate   TaxTemplate?      @relation("PurchaseTaxTemplate", fields: [taxTemplateId], references: [id], onDelete: SetNull)
  taxBreakdowns PurchaseTaxBreakdown[]

  @@index([purchaseDate])
  @@index([supplierId])
  @@index([branchId])
  @@index([paymentStatus])
  @@index([docstatus])
  @@map("purchases")
}

/// Purchase line items (supports live bird tracking)
/// PRD Section: 4.2.4
model PurchaseLine {
  id              Int       @id @default(autoincrement())
  purchaseId      Int       @map("purchase_id")
  lineNumber      Int       @map("line_number")
  itemId          Int       @map("item_id")
  itemName        String    @map("item_name")
  itemCode        String    @map("item_code")
  weightGrams     Int       @map("weight_grams")
  pricePerKg      Int       @map("price_per_kg") // Minor units
  taxRatePct      Int       @default(0) @map("tax_rate_pct")
  taxAmount       Int       @default(0) @map("tax_amount")
  lineTotalAmount Int       @map("line_total_amount")
  lotNumber       String?   @map("lot_number")
  expiryDate      DateTime? @map("expiry_date")
  isLiveBird      Boolean   @default(false) @map("is_live_bird")
  metadata        String? // JSON: gross_weight, net_weight, shrinkage_pct
  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  purchase      Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  item          Item           @relation(fields: [itemId], references: [id], onDelete: Restrict)
  inventoryLots InventoryLot[]

  @@unique([purchaseId, lineNumber])
  @@index([itemId])
  @@map("purchase_lines")
}

/// Payment receipts and disbursements
/// PRD Section: 4.2.5
/// Blueprint 03: docstatus (1=Submitted on create, 2=Cancelled with GL reversal)
model Payment {
  id                Int      @id @default(autoincrement())
  paymentNumber     String   @unique @map("payment_number")
  paymentDate       DateTime @default(now()) @map("payment_date")
  amount            Int // Minor units (can be negative for refunds)
  paymentMethod     String   @map("payment_method") // 'cash', 'card', 'bank_transfer', 'mobile', 'check'
  referenceType     String?  @map("reference_type") // 'sale', 'purchase', 'expense', 'debt', null=advance
  referenceId       Int?     @map("reference_id")
  partyType         String?  @map("party_type") // 'customer', 'supplier'
  partyId           Int?     @map("party_id")
  partyName         String?  @map("party_name")
  receiptNumber     String?  @map("receipt_number")
  bankTransactionId String?  @map("bank_transaction_id")
  receivedById      Int?     @map("received_by")
  branchId          Int?     @map("branch_id")
  isVoided          Boolean  @default(false) @map("is_voided")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Blueprint 03: Posting workflow (Payment submitted on create; cancel creates GL reversal)
  docstatus     Int       @default(1) @map("docstatus") // 1=Submitted, 2=Cancelled
  cancelledAt   DateTime? @map("cancelled_at")
  cancelledById Int?      @map("cancelled_by")
  cancelReason  String?   @map("cancel_reason")

  // Relations
  receivedBy   User?   @relation(fields: [receivedById], references: [id], onDelete: SetNull)
  cancelledBy  User?   @relation("PaymentCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  branch       Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  allocations  PaymentAllocation[] @relation // Blueprint 04: multi-invoice allocation

  @@index([paymentDate])
  @@index([referenceType, referenceId])
  @@index([partyType, partyId])
  @@index([docstatus])
  @@map("payments")
}

/// Blueprint 04: Payment Ledger Entry (Subledger for Receivables/Payables)
/// Tracks voucher-level impact on party balances (source of truth for Outstanding)
model PaymentLedgerEntry {
  id                   Int      @id @default(autoincrement())
  partyType            String   @map("party_type")   // 'customer', 'supplier'
  partyId              Int      @map("party_id")
  accountType          String   @map("account_type") // 'receivable', 'payable'
  accountId            Int      @map("account_id")

  voucherType          String   @map("voucher_type") // 'sale', 'purchase', 'payment', 'credit_note'
  voucherId            Int      @map("voucher_id")

  againstVoucherType   String?   @map("against_voucher_type")
  againstVoucherId    Int?      @map("against_voucher_id")

  amount               Int      @map("amount")       // + for invoice (increase AR), - for payment (decrease AR)
  postingDate          DateTime @map("posting_date")
  dueDate              DateTime? @map("due_date")
  remarks              String?
  delinked             Boolean  @default(false) @map("delinked")

  createdAt            DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([partyType, partyId])
  @@index([voucherType, voucherId])
  @@index([againstVoucherType, againstVoucherId])
  @@index([postingDate])
  @@map("payment_ledger_entries")
}

/// Blueprint 04: Payment allocation to invoices (partial + multi-invoice)
model PaymentAllocation {
  id              Int      @id @default(autoincrement())
  paymentId       Int      @map("payment_id")
  invoiceType     String   @map("invoice_type")   // 'sale', 'purchase'
  invoiceId       Int      @map("invoice_id")
  allocatedAmount Int      @map("allocated_amount")
  createdAt       DateTime @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([paymentId, invoiceType, invoiceId])
  @@index([invoiceType, invoiceId])
  @@map("payment_allocations")
}

/// Blueprint 04: Credit Note (independent document for partial returns/discounts)
model CreditNote {
  id                  Int       @id @default(autoincrement())
  creditNoteNumber    String    @unique @map("credit_note_number")
  creditNoteDate      DateTime  @default(now()) @map("credit_note_date")
  docstatus           Int       @default(0) @map("docstatus")

  originalInvoiceType String    @map("original_invoice_type")
  originalInvoiceId   Int       @map("original_invoice_id")
  amount              Int       @map("amount")
  reason              String?
  branchId            Int?      @map("branch_id")
  createdById         Int?      @map("created_by")
  submittedAt         DateTime? @map("submitted_at")
  submittedById       Int?      @map("submitted_by")
  cancelledAt         DateTime? @map("cancelled_at")
  cancelledById       Int?      @map("cancelled_by")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  branch     Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBy  User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([originalInvoiceType, originalInvoiceId])
  @@map("credit_notes")
}

/// Receivables and Payables tracking
/// PRD Section: 4.2.5
model Debt {
  id          Int       @id @default(autoincrement())
  debtNumber  String    @unique @map("debt_number")
  direction   String // 'receivable' (owed to us), 'payable' (we owe)
  partyType   String    @map("party_type") // 'customer', 'supplier', 'employee', 'other'
  partyId     Int?      @map("party_id")
  partyName   String    @map("party_name")
  totalAmount Int       @map("total_amount") // Minor units
  amountPaid  Int       @default(0) @map("amount_paid")
  dueDate     DateTime? @map("due_date")
  sourceType  String    @map("source_type") // 'sale', 'purchase', 'expense'
  sourceId    Int       @map("source_id")
  status      String    @default("open") // 'open', 'partial', 'paid', 'overdue', 'written_off'
  branchId    Int?      @map("branch_id")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([direction])
  @@index([partyType, partyId])
  @@index([status])
  @@index([dueDate])
  @@map("debts")
}

// =============================================================================
// SECTION 5: EXPENSES
// =============================================================================

/// Expense categories with hierarchy
/// PRD Section: 4.2.7
model ExpenseCategory {
  id               Int      @id @default(autoincrement())
  code             String   @unique
  name             String // Arabic
  nameEn           String?  @map("name_en")
  accountCode      String?  @map("account_code")
  parentCategoryId Int?     @map("parent_category_id")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Self-referential
  parentCategory  ExpenseCategory?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  childCategories ExpenseCategory[] @relation("CategoryHierarchy")
  expenses        Expense[]

  @@map("expense_categories")
}

/// Operating expenses with approval workflow
/// PRD Section: 4.2.7
model Expense {
  id              Int       @id @default(autoincrement())
  expenseNumber   String    @unique @map("expense_number")
  expenseDate     DateTime  @default(now()) @map("expense_date")
  expenseType     String    @map("expense_type") // 'operational', 'personal', 'payroll', 'utilities', 'rent', 'maintenance', 'other'
  categoryId      Int?      @map("category_id")
  amount          Int // Minor units
  taxAmount       Int       @default(0) @map("tax_amount")
  description     String
  supplierId      Int?      @map("supplier_id")
  paymentMethod   String?   @map("payment_method")
  referenceNumber String?   @map("reference_number")
  isApproved      Boolean   @default(false) @map("is_approved")
  approvedById    Int?      @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  branchId        Int?      @map("branch_id")
  attachmentUrl   String?   @map("attachment_url")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdById     Int       @map("created_by")

  // Blueprint 03: Posting workflow
  docstatus     Int       @default(0) @map("docstatus") // 0=Draft, 1=Submitted, 2=Cancelled
  submittedAt   DateTime? @map("submitted_at")
  submittedById Int?      @map("submitted_by")
  cancelledAt   DateTime? @map("cancelled_at")
  cancelledById Int?      @map("cancelled_by")
  cancelReason  String?   @map("cancel_reason")

  // Relations
  category   ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supplier   Supplier?        @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  approvedBy User?            @relation("ExpenseApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  branch     Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBy  User             @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([expenseDate])
  @@index([expenseType])
  @@index([categoryId])
  @@index([docstatus])
  @@map("expenses")
}

// =============================================================================
// SECTION 6: ACCOUNTING (DOUBLE-ENTRY LEDGER)
// Blueprint 01: Chart of Accounts Rebuild - Nested Set, ERP-level controls
// =============================================================================

/// Company (multi-company support, nullable = single entity)
/// Blueprint 01: Chart of Accounts Rebuild
/// Blueprint 02: round-off account, currency precision
model Company {
  id                    Int      @id @default(autoincrement())
  code                  String   @unique
  name                  String
  nameEn                String?  @map("name_en")
  defaultCurrency       String   @default("SAR") @map("default_currency")
  fiscalYearStartMonth  Int      @default(1) @map("fiscal_year_start_month")
  isActive              Boolean  @default(true) @map("is_active")
  roundOffAccountId    Int?     @map("round_off_account_id")
  roundOffCostCenterId  Int?     @map("round_off_cost_center_id")
  currencyPrecision    Int      @default(2) @map("currency_precision")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  accounts             Account[]
  accountingPeriods     AccountingPeriod[]
  costCenters          CostCenter[]
  taxTemplates         TaxTemplate[]
  roundOffAccount      Account?  @relation("CompanyRoundOffAccount", fields: [roundOffAccountId], references: [id], onDelete: SetNull)
  roundOffCostCenter   CostCenter? @relation("CompanyRoundOffCostCenter", fields: [roundOffCostCenterId], references: [id], onDelete: SetNull) // One cost center can be round-off for multiple companies
  journalEntryLines    JournalEntryLine[]

  @@map("companies")
}

/// Chart of Accounts - Nested Set Model
/// Blueprint 01: root_type, report_type, is_group, lft/rgt for tree queries
model Account {
  id               Int      @id @default(autoincrement())
  code             String
  name             String
  nameEn           String?  @map("name_en")

  rootType         String   @map("root_type")
  reportType       String   @map("report_type")
  accountType      String   @map("account_type")

  parentId         Int?     @map("parent_id")
  lft              Int      @default(0)
  rgt              Int      @default(0)

  isGroup          Boolean  @default(false) @map("is_group")
  balanceMustBe    String?  @map("balance_must_be")
  accountCurrency  String?  @map("account_currency")
  companyId        Int?     @map("company_id")

  isActive         Boolean  @default(true) @map("is_active")
  isSystemAccount  Boolean  @default(false) @map("is_system_account")
  freezeAccount    Boolean  @default(false) @map("freeze_account")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  company           Company?  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  parent            Account?  @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  childAccounts     Account[] @relation("AccountHierarchy")
  journalEntryLines JournalEntryLine[]
  stockAccountBranches Branch[] @relation
  paymentLedgerEntries PaymentLedgerEntry[]
  companiesAsRoundOff Company[] @relation("CompanyRoundOffAccount")
  taxTemplateItems    TaxTemplateItem[]
  saleTaxBreakdowns   SaleTaxBreakdown[]
  purchaseTaxBreakdowns PurchaseTaxBreakdown[]

  @@unique([code, companyId])
  @@index([companyId])
  @@index([parentId])
  @@index([lft, rgt])
  @@index([rootType])
  @@index([reportType])
  @@index([accountType])
  @@index([isGroup])
  @@map("accounts")
}

/// Journal entry headers
/// PRD Section: 6.2
model JournalEntry {
  id                Int      @id @default(autoincrement())
  entryNumber       String   @unique @map("entry_number")
  entryDate         DateTime @default(now()) @map("entry_date")
  description       String
  sourceType        String?  @map("source_type") // 'sale', 'purchase', 'payment', 'adjustment', 'expense'
  sourceId          Int?     @map("source_id")
  isPosted          Boolean  @default(false) @map("is_posted")
  isReversed        Boolean  @default(false) @map("is_reversed")
  reversedByEntryId Int?     @map("reversed_by_entry_id")
  branchId          Int?     @map("branch_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  createdById       Int?     @map("created_by")

  // Self-referential
  reversedByEntry JournalEntry?  @relation("EntryReversal", fields: [reversedByEntryId], references: [id], onDelete: SetNull)
  reversesEntries JournalEntry[] @relation("EntryReversal")

  // Relations
  branch    Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBy User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  lines     JournalEntryLine[]

  @@index([entryDate])
  @@index([sourceType, sourceId])
  @@index([isPosted])
  @@map("journal_entries")
}

/// Journal debit/credit lines
/// Blueprint 01: account_id (was account_code) for stable references
/// Blueprint 02: cost center, party, against voucher, multi-currency
model JournalEntryLine {
  id                       Int      @id @default(autoincrement())
  journalEntryId            Int      @map("journal_entry_id")
  lineNumber                Int      @map("line_number")
  accountId                 Int      @map("account_id")
  debitAmount               Int      @default(0) @map("debit_amount")
  creditAmount              Int      @default(0) @map("credit_amount")
  debitInAccountCurrency    Int?     @map("debit_in_account_currency")
  creditInAccountCurrency   Int?     @map("credit_in_account_currency")
  exchangeRate              Float?   @map("exchange_rate")
  costCenterId              Int?     @map("cost_center_id")
  companyId                 Int?     @map("company_id")
  partyType                 String?  @map("party_type")
  partyId                   Int?     @map("party_id")
  againstVoucherType        String?  @map("against_voucher_type")
  againstVoucherId          Int?     @map("against_voucher_id")
  voucherDetailNo           String?  @map("voucher_detail_no")
  description               String?
  isOpening                 Boolean  @default(false) @map("is_opening")
  isRoundOff                Boolean  @default(false) @map("is_round_off")
  createdAt                 DateTime @default(now()) @map("created_at")

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account     @relation(fields: [accountId], references: [id], onDelete: Restrict)
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  company      Company?    @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([journalEntryId, lineNumber])
  @@index([accountId])
  @@index([companyId])
  @@index([costCenterId])
  @@index([partyType, partyId])
  @@map("journal_entry_lines")
}

// =============================================================================
// SECTION 7: SYSTEM CONFIGURATION & AUDIT
// =============================================================================

/// Key-value store for system settings
/// PRD Section: 2.1
model SystemSetting {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  value        String // JSON serialized
  description  String?
  dataType     String   @default("string") @map("data_type") // 'string', 'number', 'boolean', 'json'
  settingGroup String?  @map("setting_group")
  isSystem     Boolean  @default(false) @map("is_system")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

/// Immutable audit trail
/// PRD Section: 4.2.9
model AuditLog {
  id         Int      @id @default(autoincrement())
  timestamp  DateTime @default(now())
  userId     Int?     @map("user_id")
  username   String
  action     String // 'create', 'update', 'delete', 'void', 'login', 'logout', etc.
  entityType String   @map("entity_type")
  entityId   Int?     @map("entity_id")
  changes    String? // JSON: before/after
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  branchId   Int?     @map("branch_id")

  // Relations
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([timestamp])
  @@index([entityType, entityId])
  @@index([userId])
  @@map("audit_logs")
}

/// Accounting periods for period locking (Blueprint 03)
model AccountingPeriod {
  id         Int       @id @default(autoincrement())
  startDate  DateTime  @map("start_date")
  endDate    DateTime  @map("end_date")
  isClosed   Boolean   @default(false) @map("is_closed")
  closedAt   DateTime? @map("closed_at")
  closedById Int?      @map("closed_by")
  companyId  Int?      @map("company_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  company   Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)
  closedBy  User?    @relation(fields: [closedById], references: [id], onDelete: SetNull)

  @@unique([companyId, startDate])
  @@index([companyId, isClosed])
  @@map("accounting_periods")
}

/// Schema version tracking
model SchemaVersion {
  id          Int      @id @default(autoincrement())
  version     String   @unique
  description String?
  appliedAt   DateTime @default(now()) @map("applied_at")

  @@map("schema_versions")
}

/// Blueprint 05: Tax Template for VAT/Multi-Tax
model TaxTemplate {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  type      String   // 'sales', 'purchases'
  companyId Int?     @map("company_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company   Company?  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  items     TaxTemplateItem[]
  sales     Sale[]
  purchases Purchase[] @relation("PurchaseTaxTemplate")

  @@index([type])
  @@index([companyId])
  @@map("tax_templates")
}

/// Blueprint 05: Tax Template Item (rate, charge type, account)
model TaxTemplateItem {
  id           Int      @id @default(autoincrement())
  templateId   Int      @map("template_id")
  accountId    Int      @map("account_id")
  rate         Int      // Basis points (1500 = 15%)
  chargeType   String   @default("on_net_total") @map("charge_type") // on_net_total, on_previous_row_amount, on_previous_row_total, actual
  rowId        Int?     @map("row_id")
  fixedAmount  Int?     @map("fixed_amount")
  isDeductible Boolean  @default(true) @map("is_deductible")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  template TaxTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  account  Account    @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([templateId])
  @@map("tax_template_items")
}

/// Blueprint 05: Sale Tax Breakdown (audit per sale)
model SaleTaxBreakdown {
  id        Int      @id @default(autoincrement())
  saleId    Int      @map("sale_id")
  accountId Int      @map("account_id")
  rate      Int
  taxAmount Int      @map("tax_amount")
  createdAt DateTime @default(now()) @map("created_at")

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@map("sale_tax_breakdowns")
}

/// Blueprint 05: Purchase Tax Breakdown
model PurchaseTaxBreakdown {
  id         Int      @id @default(autoincrement())
  purchaseId Int      @map("purchase_id")
  accountId  Int      @map("account_id")
  rate       Int
  taxAmount  Int      @map("tax_amount")
  createdAt  DateTime @default(now()) @map("created_at")

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@map("purchase_tax_breakdowns")
}

/// Blueprint 02: Cost Center for GL dimensioning
model CostCenter {
  id         Int      @id @default(autoincrement())
  code       String
  name       String
  companyId  Int?     @map("company_id")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company             Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)
  journalLines        JournalEntryLine[]
  roundOffForCompanies Company[] @relation("CompanyRoundOffCostCenter")

  @@unique([code, companyId])
  @@index([companyId])
  @@map("cost_centers")
}

// =============================================================================
// SECTION: BACKUP SUBSYSTEM
// =============================================================================

/// Tracks every backup run (auto or manual)
model BackupRun {
  id              Int       @id @default(autoincrement())
  type            String    // "auto" | "manual"
  status          String    // "running" | "success" | "failed"
  startedAt       DateTime  @default(now()) @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  filename        String?
  sizeBytes       Int?      @map("size_bytes")
  checksumSha256  String?   @map("checksum_sha256")
  errorMessage    String?   @map("error_message")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([type, status])
  @@index([startedAt])
  @@map("backup_runs")
}
