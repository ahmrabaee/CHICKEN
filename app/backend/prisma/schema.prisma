// =============================================================================
// Chicken Shop POS, Inventory & Accounting System
// Prisma Schema v1.0.0
// 
// Database: SQLite
// All monetary values in minor units (fils/cents), weights in grams
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// SECTION 1: CORE SYSTEM TABLES
// =============================================================================

/// Shop locations/branches for multi-branch support
/// PRD Section: 2.1 - Branch/Outlet Configuration
model Branch {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  name         String // Arabic name (primary)
  nameEn       String?  @map("name_en")
  address      String?
  phone        String?
  hasScale     Boolean  @default(true) @map("has_scale")
  scaleComPort String?  @map("scale_com_port")
  isMainBranch Boolean  @default(false) @map("is_main_branch")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  users          User[]          @relation("DefaultBranch")
  inventory      Inventory[]
  inventoryLots  InventoryLot[]
  stockMovements StockMovement[]
  wastageRecords WastageRecord[]
  sales          Sale[]
  purchases      Purchase[]
  payments       Payment[]
  debts          Debt[]
  expenses       Expense[]
  journalEntries JournalEntry[]
  auditLogs      AuditLog[]

  @@map("branches")
}

/// System roles (Admin and Cashier only per PRD)
/// PRD Section: 3.1 - Role Definitions
model Role {
  id           Int      @id @default(autoincrement())
  name         String   @unique // 'admin' or 'cashier'
  nameAr       String   @map("name_ar")
  description  String?
  permissions  String? // JSON array: ["sales.create", "sales.view", ...]
  isSystemRole Boolean  @default(false) @map("is_system_role")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  userRoles UserRole[]

  @@map("roles")
}

/// System users (owners, cashiers)
/// PRD Section: 4.2.8 - Users & Authentication
model User {
  id                    Int       @id @default(autoincrement())
  username              String    @unique
  email                 String?   @unique
  passwordHash          String    @map("password_hash")
  fullName              String    @map("full_name")
  fullNameEn            String?   @map("full_name_en")
  phone                 String?
  employeeNumber        String?   @unique @map("employee_number")
  preferredLanguage     String    @default("ar") @map("preferred_language")
  defaultBranchId       Int?      @map("default_branch_id")
  lastLoginAt           DateTime? @map("last_login_at")
  refreshToken          String?   @map("refresh_token")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")

  // NEW FIELDS - PRD Requirements: User tracking and session management
  workStartDate        DateTime  @default(now()) @map("work_start_date")
  currentSessionToken  String?   @map("current_session_token")
  currentSessionExpiry DateTime? @map("current_session_expiry")

  isActive    Boolean  @default(true) @map("is_active")
  metadata    String? // JSON
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById Int?     @map("created_by")
  updatedById Int?     @map("updated_by")

  // Self-referential relations
  createdBy User? @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("UserUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  // Relations
  defaultBranch         Branch?         @relation("DefaultBranch", fields: [defaultBranchId], references: [id], onDelete: SetNull)
  userRoles             UserRole[]
  usersCreated          User[]          @relation("UserCreatedBy")
  usersUpdated          User[]          @relation("UserUpdatedBy")
  rolesAssigned         UserRole[]      @relation("AssignedBy")
  itemsCreated          Item[]          @relation("ItemCreatedBy")
  itemsUpdated          Item[]          @relation("ItemUpdatedBy")
  inventoryLotsCreated  InventoryLot[]  @relation("LotCreatedBy")
  stockMovements        StockMovement[]
  wastageRecorded       WastageRecord[] @relation("WastageRecordedBy")
  wastageApproved       WastageRecord[] @relation("WastageApprovedBy")
  customersCreated      Customer[]      @relation("CustomerCreatedBy")
  customersUpdated      Customer[]      @relation("CustomerUpdatedBy")
  suppliersCreated      Supplier[]      @relation("SupplierCreatedBy")
  suppliersUpdated      Supplier[]      @relation("SupplierUpdatedBy")
  salesAsCashier        Sale[]          @relation("SaleCashier")
  salesVoided           Sale[]          @relation("SaleVoidedBy")
  salesCreated          Sale[]          @relation("SaleCreatedBy")
  purchasesReceived     Purchase[]      @relation("PurchaseReceivedBy")
  purchasesApproved     Purchase[]      @relation("PurchaseApprovedBy")
  purchasesCreated      Purchase[]      @relation("PurchaseCreatedBy")
  paymentsReceived      Payment[]
  expensesApproved      Expense[]       @relation("ExpenseApprovedBy")
  expensesCreated       Expense[]       @relation("ExpenseCreatedBy")
  journalEntriesCreated JournalEntry[]
  auditLogs             AuditLog[]

  @@map("users")
}

/// Links users to roles (many-to-many)
/// PRD Section: 3.1
model UserRole {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  roleId       Int      @map("role_id")
  assignedAt   DateTime @default(now()) @map("assigned_at")
  assignedById Int?     @map("assigned_by")

  // Relations
  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("AssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// =============================================================================
// SECTION 2: PRODUCT & INVENTORY TABLES
// =============================================================================

/// Chicken product categories
/// PRD Section: 4.2.1 - Product Categories
model Category {
  id                   Int      @id @default(autoincrement())
  code                 String   @unique
  name                 String // Arabic name (primary)
  nameEn               String?  @map("name_en")
  displayOrder         Int      @default(0) @map("display_order")
  icon                 String?
  defaultShelfLifeDays Int?     @map("default_shelf_life_days")
  storageType          String?  @map("storage_type") // 'fresh', 'frozen', 'processed'
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  items Item[]

  @@map("categories")
}

/// Products sold by weight (kg only per PRD)
/// PRD Section: 4.2.1 - Item (Chicken product master)
model Item {
  id                   Int      @id @default(autoincrement())
  code                 String   @unique
  barcode              String?  @unique
  name                 String // Arabic name (primary)
  nameEn               String?  @map("name_en")
  description          String?
  categoryId           Int      @map("category_id")
  defaultSalePrice     Int      @map("default_sale_price") // Minor units per kg
  defaultPurchasePrice Int?     @map("default_purchase_price")
  taxRatePct           Int?     @map("tax_rate_pct") // Basis points
  minStockLevelGrams   Int?     @map("min_stock_level_grams")
  maxStockLevelGrams   Int?     @map("max_stock_level_grams")
  shelfLifeDays        Int?     @map("shelf_life_days")
  storageLocation      String?  @map("storage_location") // 'fridge', 'freezer', 'display'
  requiresScale        Boolean  @default(true) @map("requires_scale")
  allowNegativeStock   Boolean  @default(false) @map("allow_negative_stock")
  imageUrl             String?  @map("image_url")
  metadata             String? // JSON
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  createdById          Int?     @map("created_by")
  updatedById          Int?     @map("updated_by")

  // Relations
  category       Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy      User?           @relation("ItemCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?           @relation("ItemUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  inventory      Inventory?
  inventoryLots  InventoryLot[]
  stockMovements StockMovement[]
  wastageRecords WastageRecord[]
  saleLines      SaleLine[]
  purchaseLines  PurchaseLine[]

  @@index([categoryId])
  @@index([name])
  @@index([isActive])
  @@map("items")
}

/// Current stock summary per item (1:1 with Item)
/// PRD Section: 4.2.2
model Inventory {
  id                    Int       @id @default(autoincrement())
  itemId                Int       @unique @map("item_id")
  branchId              Int?      @map("branch_id")
  currentQuantityGrams  Int       @default(0) @map("current_quantity_grams")
  reservedQuantityGrams Int       @default(0) @map("reserved_quantity_grams")
  totalValue            Int       @default(0) @map("total_value") // Minor units
  averageCost           Int       @default(0) @map("average_cost") // Minor units per kg
  lastRestockedAt       DateTime? @map("last_restocked_at")
  lastSoldAt            DateTime? @map("last_sold_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relations
  item   Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@map("inventory")
}

/// Individual inventory lots for FIFO cost allocation
/// PRD Section: 4.2.2 - FIFO lot tracking
model InventoryLot {
  id                     Int       @id @default(autoincrement())
  itemId                 Int       @map("item_id")
  purchaseId             Int?      @map("purchase_id")
  purchaseLineId         Int?      @map("purchase_line_id")
  branchId               Int?      @map("branch_id")
  lotNumber              String    @unique @map("lot_number")
  batchNumber            String?   @map("batch_number")
  totalQuantityGrams     Int       @map("total_quantity_grams")
  remainingQuantityGrams Int       @map("remaining_quantity_grams")
  unitPurchasePrice      Int       @map("unit_purchase_price") // Minor units per kg
  receivedAt             DateTime  @default(now()) @map("received_at")
  expiryDate             DateTime? @map("expiry_date")
  metadata               String? // JSON: gross_weight, net_weight, shrinkage
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  createdById            Int?      @map("created_by")

  // Relations
  item            Item                     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  purchase        Purchase?                @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  purchaseLine    PurchaseLine?            @relation(fields: [purchaseLineId], references: [id], onDelete: SetNull)
  branch          Branch?                  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBy       User?                    @relation("LotCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  stockMovements  StockMovement[]
  wastageRecords  WastageRecord[]
  costAllocations SaleLineCostAllocation[]

  @@index([itemId, receivedAt])
  @@index([expiryDate])
  @@index([branchId])
  @@index([purchaseId])
  @@map("inventory_lots")
}

/// Audit trail for inventory changes
/// PRD Section: 4.2.2
model StockMovement {
  id            Int      @id @default(autoincrement())
  itemId        Int      @map("item_id")
  lotId         Int?     @map("lot_id")
  branchId      Int?     @map("branch_id")
  movementType  String   @map("movement_type") // 'purchase', 'sale', 'adjustment', 'transfer', 'waste', 'opening'
  quantityGrams Int      @map("quantity_grams") // Positive = in, Negative = out
  unitCost      Int?     @map("unit_cost")
  referenceType String?  @map("reference_type")
  referenceId   Int?     @map("reference_id")
  fromBranchId  Int?     @map("from_branch_id")
  toBranchId    Int?     @map("to_branch_id")
  reason        String?
  movementDate  DateTime @default(now()) @map("movement_date")
  performedById Int?     @map("performed_by")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  item        Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  lot         InventoryLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  branch      Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  performedBy User?         @relation(fields: [performedById], references: [id], onDelete: SetNull)

  @@index([itemId, movementDate])
  @@index([movementType])
  @@index([branchId])
  @@map("stock_movements")
}

/// Spoilage, trimming, expiry tracking
/// PRD Section: 4.2.2 - Critical for chicken shop daily tracking
model WastageRecord {
  id                 Int       @id @default(autoincrement())
  itemId             Int       @map("item_id")
  lotId              Int?      @map("lot_id")
  branchId           Int?      @map("branch_id")
  weightGrams        Int       @map("weight_grams")
  wastageType        String    @map("wastage_type") // 'spoilage', 'trimming', 'expired', 'damaged', 'end_of_day', 'other'
  reason             String
  estimatedCostValue Int       @default(0) @map("estimated_cost_value") // Minor units
  photoUrl           String?   @map("photo_url")
  recordedById       Int       @map("recorded_by")
  approvedById       Int?      @map("approved_by")
  approvedAt         DateTime? @map("approved_at")
  wastageDate        DateTime  @default(now()) @map("wastage_date")
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Relations
  item       Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  lot        InventoryLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  branch     Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  recordedBy User          @relation("WastageRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)
  approvedBy User?         @relation("WastageApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([wastageDate])
  @@index([wastageType])
  @@map("wastage_records")
}

// =============================================================================
// SECTION 3: PARTIES (CUSTOMERS & SUPPLIERS)
// =============================================================================

/// Customers with credit management
/// PRD Section: 4.2.6 - Customer master
model Customer {
  id                 Int      @id @default(autoincrement())
  customerNumber     String   @unique @map("customer_number")
  name               String // Arabic name (primary)
  nameEn             String?  @map("name_en")
  phone              String?
  phone2             String?
  email              String?
  address            String?
  creditLimit        Int      @default(0) @map("credit_limit") // Minor units
  currentBalance     Int      @default(0) @map("current_balance") // Computed
  priceLevel         String   @default("standard") @map("price_level") // 'standard', 'wholesale', 'vip'
  defaultDiscountPct Int      @default(0) @map("default_discount_pct") // Basis points
  taxNumber          String?  @map("tax_number")
  metadata           String? // JSON
  notes              String?
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  createdById        Int?     @map("created_by")
  updatedById        Int?     @map("updated_by")

  // Relations
  createdBy User?  @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?  @relation("CustomerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  sales     Sale[]

  @@index([phone])
  @@index([isActive])
  @@map("customers")
}

/// Chicken suppliers/farms
/// PRD Section: 4.2.6 - Supplier master
model Supplier {
  id                Int      @id @default(autoincrement())
  supplierNumber    String   @unique @map("supplier_number")
  name              String // Arabic name (primary)
  nameEn            String?  @map("name_en")
  phone             String?
  email             String?
  address           String?
  contactPerson     String?  @map("contact_person")
  taxNumber         String?  @map("tax_number")
  paymentTerms      String?  @map("payment_terms")
  currentBalance    Int      @default(0) @map("current_balance") // Computed
  creditLimit       Int?     @map("credit_limit")
  bankName          String?  @map("bank_name")
  bankAccountNumber String?  @map("bank_account_number")
  rating            Int? // 1-5
  metadata          String?
  notes             String?
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  createdById       Int?     @map("created_by")
  updatedById       Int?     @map("updated_by")

  // Relations
  createdBy User?      @relation("SupplierCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?      @relation("SupplierUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  purchases Purchase[]
  expenses  Expense[]

  @@index([isActive])
  @@map("suppliers")
}

// =============================================================================
// SECTION 4: TRANSACTIONS (SALES, PURCHASES, PAYMENTS, DEBTS)
// =============================================================================

/// Sales invoices with FIFO cost tracking
/// PRD Section: 4.2.3 - Sales header
model Sale {
  id               Int       @id @default(autoincrement())
  saleNumber       String    @unique @map("sale_number")
  saleDate         DateTime  @default(now()) @map("sale_date")
  saleType         String    @default("cash") @map("sale_type") // 'cash', 'credit', 'mixed'
  customerId       Int?      @map("customer_id")
  customerName     String?   @map("customer_name")
  customerPhone    String?   @map("customer_phone")
  cashierId        Int       @map("cashier_id")
  branchId         Int?      @map("branch_id")
  grossTotalAmount Int       @default(0) @map("gross_total_amount") // Minor units
  discountAmount   Int       @default(0) @map("discount_amount")
  discountPct      Int?      @map("discount_pct") // Basis points
  taxAmount        Int       @default(0) @map("tax_amount")
  totalAmount      Int       @default(0) @map("total_amount")
  totalCost        Int       @default(0) @map("total_cost")
  totalProfit      Int       @default(0) @map("total_profit")
  paymentStatus    String    @default("unpaid") @map("payment_status") // 'unpaid', 'partial', 'paid'
  amountPaid       Int       @default(0) @map("amount_paid")
  dueDate          DateTime? @map("due_date")
  isVoided         Boolean   @default(false) @map("is_voided")
  voidedAt         DateTime? @map("voided_at")
  voidedById       Int?      @map("voided_by")
  voidReason       String?   @map("void_reason")
  notes            String?
  metadata         String? // JSON
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  createdById      Int?      @map("created_by")

  // Relations
  customer  Customer?  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  cashier   User       @relation("SaleCashier", fields: [cashierId], references: [id], onDelete: Restrict)
  branch    Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  voidedBy  User?      @relation("SaleVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)
  createdBy User?      @relation("SaleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  saleLines SaleLine[]

  @@index([saleDate])
  @@index([customerId])
  @@index([cashierId])
  @@index([branchId])
  @@index([paymentStatus])
  @@map("sales")
}

/// Sales line items (weight-based)
/// PRD Section: 4.2.3
model SaleLine {
  id              Int      @id @default(autoincrement())
  saleId          Int      @map("sale_id")
  lineNumber      Int      @map("line_number")
  itemId          Int      @map("item_id")
  itemName        String   @map("item_name")
  itemCode        String   @map("item_code")
  weightGrams     Int      @map("weight_grams")
  pricePerKg      Int      @map("price_per_kg") // Minor units
  discountAmount  Int      @default(0) @map("discount_amount")
  netPricePerKg   Int      @map("net_price_per_kg")
  taxRatePct      Int      @default(0) @map("tax_rate_pct") // Basis points
  taxAmount       Int      @default(0) @map("tax_amount")
  lineTotalAmount Int      @map("line_total_amount")
  costPerKg       Int      @default(0) @map("cost_per_kg")
  lineTotalCost   Int      @default(0) @map("line_total_cost")
  metadata        String? // JSON
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  sale            Sale                     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  item            Item                     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  costAllocations SaleLineCostAllocation[]

  @@unique([saleId, lineNumber])
  @@index([itemId])
  @@map("sale_lines")
}

/// FIFO cost tracking - links sale lines to inventory lots
/// PRD Section: 4.2.3
model SaleLineCostAllocation {
  id                     Int      @id @default(autoincrement())
  saleLineId             Int      @map("sale_line_id")
  lotId                  Int      @map("lot_id")
  quantityAllocatedGrams Int      @map("quantity_allocated_grams")
  unitCost               Int      @map("unit_cost") // Minor units per kg
  totalCost              Int      @map("total_cost")
  createdAt              DateTime @default(now()) @map("created_at")

  // Relations
  saleLine SaleLine     @relation(fields: [saleLineId], references: [id], onDelete: Cascade)
  lot      InventoryLot @relation(fields: [lotId], references: [id], onDelete: Restrict)

  @@index([saleLineId])
  @@index([lotId])
  @@map("sale_line_cost_allocations")
}

/// Purchase orders
/// PRD Section: 4.2.4
model Purchase {
  id                    Int       @id @default(autoincrement())
  purchaseNumber        String    @unique @map("purchase_number")
  purchaseDate          DateTime  @default(now()) @map("purchase_date")
  supplierId            Int       @map("supplier_id")
  supplierName          String    @map("supplier_name")
  supplierInvoiceNumber String?   @map("supplier_invoice_number")
  totalAmount           Int       @default(0) @map("total_amount") // Minor units
  taxAmount             Int       @default(0) @map("tax_amount")
  paymentStatus         String    @default("unpaid") @map("payment_status")
  amountPaid            Int       @default(0) @map("amount_paid")
  dueDate               DateTime? @map("due_date")
  receivedById          Int?      @map("received_by")
  receivedAt            DateTime? @map("received_at")
  isApproved            Boolean   @default(false) @map("is_approved")
  approvedById          Int?      @map("approved_by")
  approvedAt            DateTime? @map("approved_at")
  branchId              Int?      @map("branch_id")
  notes                 String?
  metadata              String? // JSON: live bird details
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  createdById           Int?      @map("created_by")

  // Relations
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  receivedBy    User?          @relation("PurchaseReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)
  approvedBy    User?          @relation("PurchaseApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  branch        Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBy     User?          @relation("PurchaseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  purchaseLines PurchaseLine[]
  inventoryLots InventoryLot[]

  @@index([purchaseDate])
  @@index([supplierId])
  @@index([branchId])
  @@index([paymentStatus])
  @@map("purchases")
}

/// Purchase line items (supports live bird tracking)
/// PRD Section: 4.2.4
model PurchaseLine {
  id              Int       @id @default(autoincrement())
  purchaseId      Int       @map("purchase_id")
  lineNumber      Int       @map("line_number")
  itemId          Int       @map("item_id")
  itemName        String    @map("item_name")
  itemCode        String    @map("item_code")
  weightGrams     Int       @map("weight_grams")
  pricePerKg      Int       @map("price_per_kg") // Minor units
  taxRatePct      Int       @default(0) @map("tax_rate_pct")
  taxAmount       Int       @default(0) @map("tax_amount")
  lineTotalAmount Int       @map("line_total_amount")
  lotNumber       String?   @map("lot_number")
  expiryDate      DateTime? @map("expiry_date")
  isLiveBird      Boolean   @default(false) @map("is_live_bird")
  metadata        String? // JSON: gross_weight, net_weight, shrinkage_pct
  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  purchase      Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  item          Item           @relation(fields: [itemId], references: [id], onDelete: Restrict)
  inventoryLots InventoryLot[]

  @@unique([purchaseId, lineNumber])
  @@index([itemId])
  @@map("purchase_lines")
}

/// Payment receipts and disbursements
/// PRD Section: 4.2.5
model Payment {
  id                Int      @id @default(autoincrement())
  paymentNumber     String   @unique @map("payment_number")
  paymentDate       DateTime @default(now()) @map("payment_date")
  amount            Int // Minor units (can be negative for refunds)
  paymentMethod     String   @map("payment_method") // 'cash', 'card', 'bank_transfer', 'mobile', 'check'
  referenceType     String   @map("reference_type") // 'sale', 'purchase', 'expense', 'debt'
  referenceId       Int      @map("reference_id")
  partyType         String?  @map("party_type") // 'customer', 'supplier'
  partyId           Int?     @map("party_id")
  partyName         String?  @map("party_name")
  receiptNumber     String?  @map("receipt_number")
  bankTransactionId String?  @map("bank_transaction_id")
  receivedById      Int?     @map("received_by")
  branchId          Int?     @map("branch_id")
  isVoided          Boolean  @default(false) @map("is_voided")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  receivedBy User?   @relation(fields: [receivedById], references: [id], onDelete: SetNull)
  branch     Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([paymentDate])
  @@index([referenceType, referenceId])
  @@index([partyType, partyId])
  @@map("payments")
}

/// Receivables and Payables tracking
/// PRD Section: 4.2.5
model Debt {
  id          Int       @id @default(autoincrement())
  debtNumber  String    @unique @map("debt_number")
  direction   String // 'receivable' (owed to us), 'payable' (we owe)
  partyType   String    @map("party_type") // 'customer', 'supplier', 'employee', 'other'
  partyId     Int?      @map("party_id")
  partyName   String    @map("party_name")
  totalAmount Int       @map("total_amount") // Minor units
  amountPaid  Int       @default(0) @map("amount_paid")
  dueDate     DateTime? @map("due_date")
  sourceType  String    @map("source_type") // 'sale', 'purchase', 'expense'
  sourceId    Int       @map("source_id")
  status      String    @default("open") // 'open', 'partial', 'paid', 'overdue', 'written_off'
  branchId    Int?      @map("branch_id")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([direction])
  @@index([partyType, partyId])
  @@index([status])
  @@index([dueDate])
  @@map("debts")
}

// =============================================================================
// SECTION 5: EXPENSES
// =============================================================================

/// Expense categories with hierarchy
/// PRD Section: 4.2.7
model ExpenseCategory {
  id               Int      @id @default(autoincrement())
  code             String   @unique
  name             String // Arabic
  nameEn           String?  @map("name_en")
  accountCode      String?  @map("account_code")
  parentCategoryId Int?     @map("parent_category_id")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Self-referential
  parentCategory  ExpenseCategory?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  childCategories ExpenseCategory[] @relation("CategoryHierarchy")
  expenses        Expense[]

  @@map("expense_categories")
}

/// Operating expenses with approval workflow
/// PRD Section: 4.2.7
model Expense {
  id              Int       @id @default(autoincrement())
  expenseNumber   String    @unique @map("expense_number")
  expenseDate     DateTime  @default(now()) @map("expense_date")
  expenseType     String    @map("expense_type") // 'operational', 'personal', 'payroll', 'utilities', 'rent', 'maintenance', 'other'
  categoryId      Int?      @map("category_id")
  amount          Int // Minor units
  taxAmount       Int       @default(0) @map("tax_amount")
  description     String
  supplierId      Int?      @map("supplier_id")
  paymentMethod   String?   @map("payment_method")
  referenceNumber String?   @map("reference_number")
  isApproved      Boolean   @default(false) @map("is_approved")
  approvedById    Int?      @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  branchId        Int?      @map("branch_id")
  attachmentUrl   String?   @map("attachment_url")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdById     Int       @map("created_by")

  // Relations
  category   ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supplier   Supplier?        @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  approvedBy User?            @relation("ExpenseApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  branch     Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBy  User             @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([expenseDate])
  @@index([expenseType])
  @@index([categoryId])
  @@map("expenses")
}

// =============================================================================
// SECTION 6: ACCOUNTING (DOUBLE-ENTRY LEDGER)
// =============================================================================

/// Chart of Accounts
/// PRD Section: 6.1
model Account {
  id                Int      @id @default(autoincrement())
  code              String   @unique
  name              String // Arabic
  nameEn            String?  @map("name_en")
  accountType       String   @map("account_type") // 'asset', 'liability', 'equity', 'revenue', 'expense'
  parentAccountCode String?  @map("parent_account_code")
  isActive          Boolean  @default(true) @map("is_active")
  isSystemAccount   Boolean  @default(false) @map("is_system_account")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Self-referential
  parentAccount     Account?           @relation("AccountHierarchy", fields: [parentAccountCode], references: [code], onDelete: SetNull)
  childAccounts     Account[]          @relation("AccountHierarchy")
  journalEntryLines JournalEntryLine[]

  @@index([accountType])
  @@map("accounts")
}

/// Journal entry headers
/// PRD Section: 6.2
model JournalEntry {
  id                Int      @id @default(autoincrement())
  entryNumber       String   @unique @map("entry_number")
  entryDate         DateTime @default(now()) @map("entry_date")
  description       String
  sourceType        String?  @map("source_type") // 'sale', 'purchase', 'payment', 'adjustment', 'expense'
  sourceId          Int?     @map("source_id")
  isPosted          Boolean  @default(false) @map("is_posted")
  isReversed        Boolean  @default(false) @map("is_reversed")
  reversedByEntryId Int?     @map("reversed_by_entry_id")
  branchId          Int?     @map("branch_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  createdById       Int?     @map("created_by")

  // Self-referential
  reversedByEntry JournalEntry?  @relation("EntryReversal", fields: [reversedByEntryId], references: [id], onDelete: SetNull)
  reversesEntries JournalEntry[] @relation("EntryReversal")

  // Relations
  branch    Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBy User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  lines     JournalEntryLine[]

  @@index([entryDate])
  @@index([sourceType, sourceId])
  @@index([isPosted])
  @@map("journal_entries")
}

/// Journal debit/credit lines
/// PRD Section: 6.2
model JournalEntryLine {
  id             Int      @id @default(autoincrement())
  journalEntryId Int      @map("journal_entry_id")
  lineNumber     Int      @map("line_number")
  accountCode    String   @map("account_code")
  debitAmount    Int      @default(0) @map("debit_amount") // Minor units
  creditAmount   Int      @default(0) @map("credit_amount")
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountCode], references: [code], onDelete: Restrict)

  @@unique([journalEntryId, lineNumber])
  @@index([accountCode])
  @@map("journal_entry_lines")
}

// =============================================================================
// SECTION 7: SYSTEM CONFIGURATION & AUDIT
// =============================================================================

/// Key-value store for system settings
/// PRD Section: 2.1
model SystemSetting {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  value        String // JSON serialized
  description  String?
  dataType     String   @default("string") @map("data_type") // 'string', 'number', 'boolean', 'json'
  settingGroup String?  @map("setting_group")
  isSystem     Boolean  @default(false) @map("is_system")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

/// Immutable audit trail
/// PRD Section: 4.2.9
model AuditLog {
  id         Int      @id @default(autoincrement())
  timestamp  DateTime @default(now())
  userId     Int?     @map("user_id")
  username   String
  action     String // 'create', 'update', 'delete', 'void', 'login', 'logout', etc.
  entityType String   @map("entity_type")
  entityId   Int?     @map("entity_id")
  changes    String? // JSON: before/after
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  branchId   Int?     @map("branch_id")

  // Relations
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([timestamp])
  @@index([entityType, entityId])
  @@index([userId])
  @@map("audit_logs")
}

/// Schema version tracking
model SchemaVersion {
  id          Int      @id @default(autoincrement())
  version     String   @unique
  description String?
  appliedAt   DateTime @default(now()) @map("applied_at")

  @@map("schema_versions")
}
